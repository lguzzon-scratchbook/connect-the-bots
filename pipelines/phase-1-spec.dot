digraph phase1_eleanor_schema {
    label="Phase 1: Eleanor Workflow Schema + Domain Model"
    goal="Create 7 canonical workflow tables, TypeScript types, migration SQL, and seed data for the Eleanor AI workflow engine"
    model="sonnet"


    start [
        label="Start"
        shape="Mdiamond"
        prompt="Begin Phase 1 of the Eleanor Workflow Engine: Schema + Domain Model. This phase replaces 15+ legacy scattered workflow tables with 7 canonical tables. No prior phase dependencies."
    ]

    write_types [
        label="Write types.ts"
        shape="box"
        timeout=20m
        allowed_tools="Read,Write,Glob,Bash"
        prompt="Create the file apps/api/src/workflow/types.ts from scratch with all TypeScript enums, const arrays, union types, and row interfaces for the Eleanor workflow engine. The file must export the following sections in order: (1) ID generation: import nanoid; export const genId = (prefix: string) => prefix + nanoid(). Prefixes: rel_, wfi_, wft_, wfe_, art_, sup_, vrf_. (2) RELATIONSHIP_STAGES as const array: target, attempting_contact, conversation_active, nurturing, qualified_opportunity, account_open, implementing, improving, dormant_customer, closed_won, closed_lost, do_not_pursue. Export type RelationshipStage and TERMINAL_RELATIONSHIP_STAGES readonly array (closed_won, closed_lost, do_not_pursue). (3) WORKFLOW_TYPES as const: cold_outreach, follow_up, nurture, qualification, post_account, implementation, improvement. Export WorkflowType. (4) WORKFLOW_STATES as const: not_started, ready, in_progress, waiting_on_prospect, waiting_on_rosco, scheduled, blocked, completed, stopped. Export WorkflowState and TERMINAL_WORKFLOW_STATES (completed, stopped). (5) Substate const arrays and types: COLD_OUTREACH_SUBSTATES (target_selected, research_ready, contact_verification_needed, draft_needed, draft_in_review, approved_for_send, send_scheduled, sent_waiting_reply, reply_triage_needed, sequence_exhausted), FOLLOW_UP_SUBSTATES (waiting_followup_window, insight_needed, draft_needed, scheduled, sent_waiting_reply, reply_triage_needed, exhausted), NURTURE_SUBSTATES (parked_until_signal, nurture_due, evidence_collection, draft_needed, scheduled, waiting_response, paused_by_policy), QUALIFICATION_SUBSTATES (inbound_reply_open, discovery_needed, discovery_scheduled, proposal_requested, proposal_pending, decision_pending, stalled), IMPLEMENTATION_SUBSTATES (kickoff_needed, access_needed, baseline_pending, setup_in_progress, deliverable_pending, handoff_pending, baseline_complete), IMPROVEMENT_SUBSTATES (review_due, analysis_in_progress, recommendation_pending, waiting_customer, expansion_opportunity, paused_low_engagement). Export each substate type and export union type WorkflowSubstate covering all six. (6) TASK_TYPES as const: research_company, verify_contact, generate_draft, review_draft, dispatch_message, triage_reply, schedule_call, prepare_onboarding, deliver_baseline_report, deliver_audit, close_verification_gap, generate_nurture_content, collect_evidence, send_followup. Export TaskType. (7) TASK_STATUSES as const: pending, ready, in_progress, waiting, blocked, completed, cancelled. Export TaskStatus. (8) EVENT_TYPES as const: relationship_created, relationship_stage_changed, workflow_started, workflow_state_changed, workflow_completed, workflow_stopped, task_created, task_started, task_completed, task_cancelled, message_drafted, message_sent, reply_received, suppression_applied, suppression_revoked, timer_fired, verification_failed, verification_recovered. Export EventType. (9) ACTOR_TYPES as const: system, user, worker, mailbox, webhook. Export ActorType. (10) TRIGGER_TYPES as const (human): operator_started_workflow, operator_approved_draft, operator_completed_task, operator_applied_suppression, operator_closed_workflow; (system): scheduler_fired, retry_due, nurture_window_opened, verification_job_flagged_issue, deadline_reached; (external): reply_received, bounce_received, unsubscribe_received, meeting_booked, payment_or_account_created, onboarding_form_submitted; (derived): sequence_exhausted, qualification_threshold_met, implementation_success_criteria_met, customer_became_dormant. Export TriggerType. (11) WAITING_ON_VALUES as const: prospect, rosco, system, none. Export WaitingOn. (12) SUPPRESSION_TYPES as const: do_not_contact, invalid_contact, explicit_opt_out, legal_hold, paused_until, customer_pause. Export SuppressionType. SUPPRESSION_SCOPES: relationship, contact, channel, workflow. Export SuppressionScope. SUPPRESSION_STATUSES: active, expiring, revoked. Export SuppressionStatus. (13) ARTIFACT_TYPES as const: draft, outbound_message, delivery_attempt, inbox_message, reply_classification, meeting_note, proposal, report, implementation_note. Export ArtifactType. ARTIFACT_DIRECTIONS: outbound, inbound, internal. Export ArtifactDirection. (14) FINDING_TYPES as const: missing_next_action, duplicate_active_workflow, illegal_transition_attempt, task_without_owner, overdue_waiting_state, queue_mismatch, artifact_without_workflow, stuck_blocked, orphaned_artifact. Export FindingType. FINDING_SEVERITIES: info, warning, error. FindingSeverity. FINDING_STATUSES: open, acknowledged, resolved, suppressed. FindingStatus. (15) Row interfaces matching SQL schema exactly — all IDs are string, all timestamps are Date, nullable fields are T | null (not optional), jsonb fields are Record<string, unknown>, artifact_refs is string[]: export interface Relationship { id: string; company_id: string; company_name: string; primary_contact_email: string | null; primary_contact_name: string | null; domain: string | null; city: string | null; niche: string | null; relationship_stage: RelationshipStage; active_workflow_instance_id: string | null; owner_user_id: string | null; next_action: string | null; next_action_at: Date | null; waiting_on: WaitingOn | null; blocking_reason: string | null; memory_summary: string | null; context: Record<string, unknown>; last_meaningful_event_at: Date | null; closed_reason: string | null; version: number; created_at: Date; updated_at: Date; }. export interface WorkflowInstance { id: string; relationship_id: string; workflow_type: WorkflowType; workflow_version: number; state: WorkflowState; substate: string | null; owner_user_id: string | null; next_action: string | null; next_action_at: Date | null; due_at: Date | null; waiting_on: WaitingOn | null; blocking_reason: string | null; context: Record<string, unknown>; started_at: Date; entered_state_at: Date; completed_at: Date | null; stopped_at: Date | null; exit_reason: string | null; is_active: boolean; version: number; created_at: Date; updated_at: Date; }. export interface WorkflowTask { id: string; workflow_instance_id: string; task_type: TaskType; status: TaskStatus; assignee_user_id: string | null; priority: number; due_at: Date | null; started_at: Date | null; completed_at: Date | null; blocked_reason: string | null; payload: Record<string, unknown>; artifact_refs: string[]; created_at: Date; updated_at: Date; }. export interface WorkflowEvent { id: string; relationship_id: string; workflow_instance_id: string | null; workflow_task_id: string | null; event_type: EventType; from_state: string | null; to_state: string | null; actor_type: ActorType; actor_id: string | null; reason_code: string | null; correlation_id: string | null; metadata: Record<string, unknown>; occurred_at: Date; created_row_at: Date; }. export interface CommunicationArtifact { id: string; relationship_id: string; workflow_instance_id: string | null; workflow_task_id: string | null; artifact_type: ArtifactType; provider: string | null; provider_id: string | null; thread_id: string | null; direction: ArtifactDirection | null; status: string | null; summary: string | null; payload: Record<string, unknown>; occurred_at: Date | null; created_at: Date; updated_at: Date; }. export interface Suppression { id: string; relationship_id: string; scope: SuppressionScope; suppression_type: SuppressionType; status: SuppressionStatus; starts_at: Date; ends_at: Date | null; reason: string | null; metadata: Record<string, unknown>; created_at: Date; updated_at: Date; }. export interface VerificationFinding { id: string; relationship_id: string | null; workflow_instance_id: string | null; workflow_task_id: string | null; finding_type: FindingType; severity: FindingSeverity; status: FindingStatus; summary: string; details: Record<string, unknown>; detected_at: Date; resolved_at: Date | null; created_at: Date; updated_at: Date; }."
    ]

    verify_types [
        label="Types compile?"
        shape="diamond"
        timeout=10m
        node_type="conditional"
        allowed_tools="Read,Bash"
        goal_gate=true
        prompt="Verify that apps/api/src/workflow/types.ts compiles with no TypeScript errors. Run tsc --noEmit using the project tsconfig (try: cd apps/api && npx tsc --noEmit, or check for a tsconfig.json and run accordingly). Check for: (1) All const arrays declared with 'as const' so derived types are literal string unions not widened to string. (2) All row interfaces use T | null for nullable fields, never optional ?:. (3) WorkflowSubstate union type covers all six substate union members. (4) genId function properly typed — takes string prefix, returns string. (5) No missing imports (nanoid must be imported). (6) No duplicate identifiers. (7) All exported interfaces have every field from the spec. Emit PASS if tsc exits with code 0 and no errors are printed. Emit FAIL if any type errors, missing exports, or import failures are found — include the error messages in your output."
    ]

    fix_types [
        label="Fix type errors"
        shape="box"
        timeout=15m
        allowed_tools="Read,Write,Bash"
        prompt="Fix all TypeScript compilation errors in apps/api/src/workflow/types.ts. Read the current file content and the tsc error output. Apply targeted fixes: (1) If arrays lack 'as const' — add it so (typeof ARRAY)[number] produces a union of literals not string. (2) If nullable fields use optional syntax ?: — change to T | null. (3) If nanoid import fails — check the project's package.json for the correct import path (may be 'nanoid' as ESM or require a specific import style). (4) If an interface is missing fields — add them. (5) If union types are missing members — add them. Do not rewrite working sections. After fixing, re-read the file to confirm the fix looks correct before finishing."
    ]

    write_migration [
        label="Write migration SQL"
        shape="box"
        timeout=20m
        allowed_tools="Read,Write,Glob,Bash"
        prompt="Create the file sql/migrations/0007_eleanor_workflow_schema.sql. The entire file must be wrapped in BEGIN; ... COMMIT;. Structure it in three sections: DROPS, CREATES, and ALTER for the circular FK. SECTION 1 — DROP legacy tables (all with IF EXISTS ... CASCADE, in dependency order): DROP TABLE IF EXISTS outreach_engagement_events CASCADE; DROP TABLE IF EXISTS outreach_delivery_attempts CASCADE; DROP TABLE IF EXISTS outreach_messages CASCADE; DROP TABLE IF EXISTS inbox_messages CASCADE; DROP TABLE IF EXISTS outreach_item_events CASCADE; DROP TABLE IF EXISTS outreach_items CASCADE; DROP TABLE IF EXISTS outreach_drafts CASCADE; DROP TABLE IF EXISTS outreach_logs CASCADE; DROP TABLE IF EXISTS outreach_experiments CASCADE; DROP TABLE IF EXISTS outreach_suppression_list CASCADE; DROP TABLE IF EXISTS audit_requests CASCADE; DROP TABLE IF EXISTS lead_events CASCADE; DROP TABLE IF EXISTS lead_competitors CASCADE; DROP TABLE IF EXISTS leads CASCADE; DROP TABLE IF EXISTS free_report_confirmations CASCADE; DROP TABLE IF EXISTS app_state_snapshots CASCADE; SECTION 2 — CREATE the 7 new tables in dependency order: TABLE 1 relationships — id text PRIMARY KEY, company_id text NOT NULL, company_name text NOT NULL, primary_contact_email text, primary_contact_name text, domain text, city text, niche text, relationship_stage text NOT NULL DEFAULT 'target', active_workflow_instance_id text (no FK yet — circular dependency resolved in section 3), owner_user_id text, next_action text, next_action_at timestamptz, waiting_on text, blocking_reason text, memory_summary text, context jsonb NOT NULL DEFAULT '{}'::jsonb, last_meaningful_event_at timestamptz, closed_reason text, version integer NOT NULL DEFAULT 1, created_at timestamptz NOT NULL DEFAULT now(), updated_at timestamptz NOT NULL DEFAULT now(). Indexes: CREATE INDEX idx_relationships_stage_action ON relationships (relationship_stage, next_action_at); CREATE INDEX idx_relationships_owner_action ON relationships (owner_user_id, next_action_at) WHERE owner_user_id IS NOT NULL; CREATE INDEX idx_relationships_active_workflow ON relationships (active_workflow_instance_id) WHERE active_workflow_instance_id IS NOT NULL; CREATE UNIQUE INDEX idx_relationships_company_id ON relationships (company_id); CREATE INDEX idx_relationships_domain ON relationships (lower(domain)) WHERE domain IS NOT NULL; CREATE INDEX idx_relationships_email ON relationships (lower(primary_contact_email)) WHERE primary_contact_email IS NOT NULL. TABLE 2 workflow_instances — id text PRIMARY KEY, relationship_id text NOT NULL REFERENCES relationships(id), workflow_type text NOT NULL, workflow_version integer NOT NULL DEFAULT 1, state text NOT NULL DEFAULT 'not_started', substate text, owner_user_id text, next_action text, next_action_at timestamptz, due_at timestamptz, waiting_on text, blocking_reason text, context jsonb NOT NULL DEFAULT '{}'::jsonb, started_at timestamptz NOT NULL DEFAULT now(), entered_state_at timestamptz NOT NULL DEFAULT now(), completed_at timestamptz, stopped_at timestamptz, exit_reason text, is_active boolean NOT NULL DEFAULT true, version integer NOT NULL DEFAULT 1, created_at timestamptz NOT NULL DEFAULT now(), updated_at timestamptz NOT NULL DEFAULT now(). Indexes: CREATE UNIQUE INDEX idx_workflow_instances_one_active ON workflow_instances (relationship_id) WHERE is_active = true; CREATE INDEX idx_workflow_instances_type_state ON workflow_instances (workflow_type, state, next_action_at); CREATE INDEX idx_workflow_instances_owner ON workflow_instances (owner_user_id, state, due_at) WHERE owner_user_id IS NOT NULL; CREATE INDEX idx_workflow_instances_relationship ON workflow_instances (relationship_id, is_active). TABLE 3 workflow_tasks — id text PRIMARY KEY, workflow_instance_id text NOT NULL REFERENCES workflow_instances(id), task_type text NOT NULL, status text NOT NULL DEFAULT 'pending', assignee_user_id text, priority integer NOT NULL DEFAULT 100, due_at timestamptz, started_at timestamptz, completed_at timestamptz, blocked_reason text, payload jsonb NOT NULL DEFAULT '{}'::jsonb, artifact_refs jsonb NOT NULL DEFAULT '[]'::jsonb, created_at timestamptz NOT NULL DEFAULT now(), updated_at timestamptz NOT NULL DEFAULT now(). Indexes: CREATE INDEX idx_workflow_tasks_instance_status ON workflow_tasks (workflow_instance_id, status, due_at); CREATE INDEX idx_workflow_tasks_assignee ON workflow_tasks (assignee_user_id, status, due_at) WHERE assignee_user_id IS NOT NULL; CREATE INDEX idx_workflow_tasks_type_status ON workflow_tasks (task_type, status). TABLE 4 workflow_events — id text PRIMARY KEY, relationship_id text NOT NULL REFERENCES relationships(id), workflow_instance_id text REFERENCES workflow_instances(id), workflow_task_id text REFERENCES workflow_tasks(id), event_type text NOT NULL, from_state text, to_state text, actor_type text NOT NULL, actor_id text, reason_code text, correlation_id text, metadata jsonb NOT NULL DEFAULT '{}'::jsonb, occurred_at timestamptz NOT NULL DEFAULT now(), created_row_at timestamptz NOT NULL DEFAULT now(). Indexes: CREATE INDEX idx_workflow_events_relationship ON workflow_events (relationship_id, occurred_at DESC); CREATE INDEX idx_workflow_events_instance ON workflow_events (workflow_instance_id, occurred_at DESC) WHERE workflow_instance_id IS NOT NULL; CREATE INDEX idx_workflow_events_type ON workflow_events (event_type, occurred_at DESC); CREATE INDEX idx_workflow_events_correlation ON workflow_events (correlation_id) WHERE correlation_id IS NOT NULL. TABLE 5 communication_artifacts — id text PRIMARY KEY, relationship_id text NOT NULL REFERENCES relationships(id), workflow_instance_id text REFERENCES workflow_instances(id), workflow_task_id text REFERENCES workflow_tasks(id), artifact_type text NOT NULL, provider text, provider_id text, thread_id text, direction text, status text, summary text, payload jsonb NOT NULL DEFAULT '{}'::jsonb, occurred_at timestamptz, created_at timestamptz NOT NULL DEFAULT now(), updated_at timestamptz NOT NULL DEFAULT now(). Indexes: CREATE INDEX idx_artifacts_relationship ON communication_artifacts (relationship_id, artifact_type, created_at DESC); CREATE INDEX idx_artifacts_workflow ON communication_artifacts (workflow_instance_id, artifact_type) WHERE workflow_instance_id IS NOT NULL; CREATE INDEX idx_artifacts_thread ON communication_artifacts (thread_id) WHERE thread_id IS NOT NULL; CREATE INDEX idx_artifacts_provider ON communication_artifacts (provider, provider_id) WHERE provider_id IS NOT NULL. TABLE 6 suppressions — id text PRIMARY KEY, relationship_id text NOT NULL REFERENCES relationships(id), scope text NOT NULL, suppression_type text NOT NULL, status text NOT NULL DEFAULT 'active', starts_at timestamptz NOT NULL DEFAULT now(), ends_at timestamptz, reason text, metadata jsonb NOT NULL DEFAULT '{}'::jsonb, created_at timestamptz NOT NULL DEFAULT now(), updated_at timestamptz NOT NULL DEFAULT now(). Indexes: CREATE INDEX idx_suppressions_relationship ON suppressions (relationship_id, status); CREATE INDEX idx_suppressions_active ON suppressions (status, suppression_type) WHERE status = 'active'; CREATE INDEX idx_suppressions_expiring ON suppressions (ends_at) WHERE ends_at IS NOT NULL AND status = 'active'. TABLE 7 verification_findings — id text PRIMARY KEY, relationship_id text REFERENCES relationships(id), workflow_instance_id text REFERENCES workflow_instances(id), workflow_task_id text REFERENCES workflow_tasks(id), finding_type text NOT NULL, severity text NOT NULL, status text NOT NULL DEFAULT 'open', summary text NOT NULL, details jsonb NOT NULL DEFAULT '{}'::jsonb, detected_at timestamptz NOT NULL DEFAULT now(), resolved_at timestamptz, created_at timestamptz NOT NULL DEFAULT now(), updated_at timestamptz NOT NULL DEFAULT now(). Indexes: CREATE INDEX idx_findings_status ON verification_findings (status, severity); CREATE INDEX idx_findings_relationship ON verification_findings (relationship_id) WHERE relationship_id IS NOT NULL; CREATE INDEX idx_findings_type ON verification_findings (finding_type, status). SECTION 3 — Add circular FK: ALTER TABLE relationships ADD CONSTRAINT fk_relationships_active_workflow FOREIGN KEY (active_workflow_instance_id) REFERENCES workflow_instances(id);"
    ]

    verify_migration [
        label="Migration runs clean?"
        shape="diamond"
        timeout=10m
        node_type="conditional"
        allowed_tools="Read,Bash"
        goal_gate=true
        prompt="Verify that sql/migrations/0007_eleanor_workflow_schema.sql executes without errors. Steps: (1) Check the DATABASE_URL environment variable is set. (2) Run the migration: psql $DATABASE_URL -f sql/migrations/0007_eleanor_workflow_schema.sql. Capture the exit code and output. (3) If successful, verify the 7 new tables exist by running: psql $DATABASE_URL -c \"SELECT table_name FROM information_schema.tables WHERE table_schema='public' ORDER BY table_name;\" and confirm relationships, workflow_instances, workflow_tasks, workflow_events, communication_artifacts, suppressions, verification_findings are all present. (4) Verify legacy tables are gone: leads, outreach_items, outreach_drafts, outreach_messages, inbox_messages, outreach_delivery_attempts, outreach_engagement_events, outreach_item_events, outreach_logs, outreach_experiments, outreach_suppression_list, audit_requests, lead_events, lead_competitors, app_state_snapshots should NOT appear in the table list. (5) Verify non-workflow tables are intact: brands, prompts, scan_runs, report_runs, org_subscriptions should still be present. (6) Verify the unique partial index on workflow_instances exists: psql $DATABASE_URL -c \"SELECT indexname FROM pg_indexes WHERE tablename='workflow_instances' AND indexname='idx_workflow_instances_one_active';\" (7) Verify the circular FK was added: psql $DATABASE_URL -c \"SELECT constraint_name FROM information_schema.table_constraints WHERE table_name='relationships' AND constraint_type='FOREIGN KEY';\" and confirm fk_relationships_active_workflow is present. Emit PASS if migration exits 0, all 7 tables exist, all legacy tables are gone, and non-workflow tables are intact. Emit FAIL with specific error details otherwise."
    ]

    fix_migration [
        label="Fix migration errors"
        shape="box"
        timeout=15m
        allowed_tools="Read,Write,Bash"
        prompt="Fix errors in sql/migrations/0007_eleanor_workflow_schema.sql based on the psql error output. Common issues: (1) FK creation order error — relationships must be created BEFORE workflow_instances but WITHOUT the active_workflow_instance_id FK (which creates the circular dependency). The FK must be added via ALTER TABLE after both tables exist. Check that the DROP and CREATE order is correct. (2) 'table does not exist' on DROP — ensure all DROP statements use IF EXISTS. (3) jsonb default syntax — must be '{}'::jsonb and '[]'::jsonb with explicit cast. (4) Partial index WHERE clause syntax — must be a simple column condition e.g. WHERE is_active = true, WHERE owner_user_id IS NOT NULL. (5) Constraint name conflicts from a previous failed run — add DROP CONSTRAINT IF EXISTS before adding constraints, or wrap in a DO $$ block. (6) Transaction aborted mid-way — fix the error that caused the abort, then the whole BEGIN/COMMIT block will retry clean. Do not remove the BEGIN/COMMIT wrapper."
    ]

    write_seed [
        label="Write seed.ts"
        shape="box"
        timeout=20m
        allowed_tools="Read,Write,Glob,Bash"
        prompt="Create the file apps/api/src/workflow/seed.ts. First, read existing database client files to find how the project connects to PostgreSQL (check apps/api/src/db.ts, apps/api/src/database.ts, or similar). Also read apps/api/src/workflow/types.ts to confirm the genId import path. The seed script must export an async function seedWorkflow() and include a main guard (if require.main === module or if import.meta.url === ...) to call it. The function must insert 3 relationships, 3 workflow instances, 3 workflow tasks, and 6 workflow events in the following order to avoid FK violations: STEP 1 — Insert 3 relationships with active_workflow_instance_id = NULL: (a) Acme Corp: id=genId('rel_'), company_id='company_acme', company_name='Acme Corp', domain='acmecorp.com', relationship_stage='attempting_contact', version=1. (b) Widget Inc: id=genId('rel_'), company_id='company_widget', company_name='Widget Inc', domain='widgetinc.com', relationship_stage='nurturing', version=1. (c) TechStart LLC: id=genId('rel_'), company_id='company_techstart', company_name='TechStart LLC', domain='techstart.io', relationship_stage='implementing', version=1. STEP 2 — Insert 3 workflow instances: (a) Acme cold_outreach: id=genId('wfi_'), relationship_id=acme.id, workflow_type='cold_outreach', workflow_version=1, state='in_progress', substate='draft_needed', is_active=true, version=1. (b) Widget nurture: id=genId('wfi_'), relationship_id=widget.id, workflow_type='nurture', workflow_version=1, state='scheduled', substate='parked_until_signal', is_active=true, next_action_at=30 days from now, version=1. (c) TechStart implementation: id=genId('wfi_'), relationship_id=techstart.id, workflow_type='implementation', workflow_version=1, state='in_progress', substate='setup_in_progress', is_active=true, version=1. STEP 3 — Insert 3 workflow tasks: (a) Acme task: id=genId('wft_'), workflow_instance_id=acmeWfi.id, task_type='generate_draft', status='ready', priority=100. (b) Widget task: id=genId('wft_'), workflow_instance_id=widgetWfi.id, task_type='generate_nurture_content', status='pending', priority=100, due_at=30 days from now. (c) TechStart task: id=genId('wft_'), workflow_instance_id=techstartWfi.id, task_type='deliver_baseline_report', status='in_progress', priority=100, started_at=now. STEP 4 — Insert 6 workflow events (relationship_created and workflow_started for each): For each relationship emit a relationship_created event (actor_type='system', event_type='relationship_created'), and for each workflow instance emit a workflow_started event (actor_type='system', event_type='workflow_started', from_state=null, to_state='in_progress' or 'scheduled' as appropriate). All event IDs use genId('wfe_'). STEP 5 — UPDATE relationships to set active_workflow_instance_id: UPDATE relationships SET active_workflow_instance_id=acmeWfi.id WHERE id=acme.id; same for widget and techstart. Use the project's db client to run all inserts. If the project uses a query builder (Drizzle, Kysely) use it; if raw SQL use parameterized queries. Log 'Seed complete' on success. Handle errors by logging and re-throwing."
    ]

    verify_seed [
        label="Seed + canonical queries pass?"
        shape="diamond"
        timeout=10m
        node_type="conditional"
        allowed_tools="Read,Bash"
        goal_gate=true
        prompt="Verify the seed script runs and the five canonical queries return correct results. (1) Run the seed script: cd apps/api && npx tsx src/workflow/seed.ts (or ts-node, whichever the project uses). Verify it exits 0. (2) Verify row counts: psql $DATABASE_URL -c 'SELECT COUNT(*) FROM relationships;' — expect 3. psql $DATABASE_URL -c 'SELECT COUNT(*) FROM workflow_instances;' — expect 3. psql $DATABASE_URL -c 'SELECT COUNT(*) FROM workflow_tasks;' — expect 3. psql $DATABASE_URL -c 'SELECT COUNT(*) FROM workflow_events;' — expect 6. (3) Run the five canonical queries for Acme Corp: Q1 (stage): SELECT relationship_stage FROM relationships WHERE company_name='Acme Corp' — expect 'attempting_contact'. Q2 (active workflow): SELECT workflow_type, state FROM workflow_instances WHERE relationship_id=(SELECT id FROM relationships WHERE company_name='Acme Corp') AND is_active=true — expect cold_outreach / in_progress. Q3 (next action): SELECT task_type, status FROM workflow_tasks WHERE workflow_instance_id=(SELECT id FROM workflow_instances WHERE relationship_id=(SELECT id FROM relationships WHERE company_name='Acme Corp') AND is_active=true) AND status IN ('pending','ready') — expect generate_draft / ready. Q4 (owner): SELECT owner_user_id FROM workflow_instances WHERE relationship_id=(SELECT id FROM relationships WHERE company_name='Acme Corp') AND is_active=true — may be null, that is acceptable. Q5 (due): SELECT next_action_at FROM workflow_instances WHERE relationship_id=(SELECT id FROM relationships WHERE company_name='Acme Corp') AND is_active=true — return value noted. (4) Verify active_workflow_instance_id back-pointer is set: SELECT active_workflow_instance_id FROM relationships WHERE company_name='Acme Corp' — must NOT be null. Emit PASS if seed exits 0, row counts are correct, Q1-Q3 return expected values, and back-pointers are set. Emit FAIL with specific details otherwise."
    ]

    fix_seed [
        label="Fix seed errors"
        shape="box"
        timeout=15m
        allowed_tools="Read,Write,Bash,Glob"
        prompt="Fix errors in apps/api/src/workflow/seed.ts based on the error output from running tsx or ts-node. Common issues: (1) FK violation on relationships insert — active_workflow_instance_id must be NULL on initial insert, then UPDATEd after workflow_instances are created. Confirm STEP 5 UPDATE is present and runs after all inserts. (2) Wrong db client import — re-read existing service files (apps/api/src/) to find the correct import. (3) genId import path wrong — re-check apps/api/src/workflow/types.ts export. (4) Canonical query Q1 returns wrong stage — check that relationship_stage is being set correctly in the INSERT. (5) Canonical query Q2 returns no rows — check that is_active=true is being set on workflow instance inserts. (6) Row count wrong — check for duplicate inserts if seed was run twice; add a cleanup block at the start: DELETE FROM workflow_events WHERE relationship_id IN (SELECT id FROM relationships WHERE company_name IN ('Acme Corp','Widget Inc','TechStart LLC')); and similarly for other tables, in reverse FK order, then re-insert. Make targeted fixes and do not break working inserts."
    ]

    verify_non_workflow [
        label="Non-workflow tables intact?"
        shape="diamond"
        timeout=10m
        node_type="conditional"
        allowed_tools="Bash,Read"
        goal_gate=true
        prompt="Verify that all non-workflow tables are intact and queryable after the migration. Run: psql $DATABASE_URL -c \"SELECT table_name FROM information_schema.tables WHERE table_schema='public' ORDER BY table_name;\" and check that each of the following tables appears in the output: brands, brand_competitors, prompts, configured_models, scan_runs, scan_entries, scan_entry_mentions, report_runs, report_details, report_artifacts, report_events, optimization_actions, optimization_action_events, optimization_kpi_snapshots, cta_funnel_events, org_subscriptions, model_config_snapshots, contact_verification_cache. Also spot-check data integrity: run SELECT COUNT(*) FROM brands; and SELECT COUNT(*) FROM scan_runs; — if either returns an error or unexpectedly zero rows (and the project is not brand new), flag it. Run SELECT COUNT(*) FROM configured_models; — should return without error. Also verify Better Auth tables exist: user, session, account, organization. Emit PASS if all non-workflow tables are present and SELECT COUNT(*) runs without error on brands, scan_runs, and configured_models. Emit FAIL if any table is missing with the specific table names that are absent."
    ]

    fix_collateral [
        label="Fix collateral damage"
        shape="box"
        timeout=15m
        allowed_tools="Read,Write,Bash"
        prompt="Fix any non-workflow tables that were accidentally dropped or damaged by the migration in sql/migrations/0007_eleanor_workflow_schema.sql. First, identify which tables are missing by diffing the expected table list against psql output. Then: (1) If the migration has an overly broad DROP statement that matched a non-workflow table — edit the migration file to be more specific and add IF EXISTS guards. (2) If a non-workflow table is missing and a pg_dump backup exists — restore it with: pg_restore -d $DATABASE_URL --table=<table_name> --data-only backup_YYYYMMDD.dump. (3) If no backup exists and the table structure is known from the codebase — reconstruct the CREATE TABLE statement from ORM schema files or migration history and re-create it. Document what was lost and what was fixed. After fixing, note that the migration file must be edited so the issue does not recur."
    ]

    commit_changes [
        label="Commit changes"
        shape="box"
        timeout=10m
        allowed_tools="Bash"
        prompt="Commit all Phase 1 changes to git. Run: git add apps/api/src/workflow/types.ts sql/migrations/0007_eleanor_workflow_schema.sql apps/api/src/workflow/seed.ts && git commit -m 'feat(eleanor): Phase 1 — schema, types, migration, and seed data\n\nCreate 7 canonical workflow tables replacing 15+ legacy tables.\nAdd TypeScript types, enums, and row interfaces.\nAdd seed script with 3 sample relationships.\nAll canonical queries verified against seed data.'"
    ]

    done [
        label="Done"
        shape="Msquare"
        prompt="Phase 1 complete. Deliverables produced: (1) apps/api/src/workflow/types.ts — all TypeScript enums, const arrays, union types, row interfaces, and genId helper, compiling with no errors. (2) sql/migrations/0007_eleanor_workflow_schema.sql — migration that drops 15 legacy tables and creates 7 canonical tables (relationships, workflow_instances, workflow_tasks, workflow_events, communication_artifacts, suppressions, verification_findings) with all indexes and the circular FK between relationships and workflow_instances. (3) apps/api/src/workflow/seed.ts — seed script creating 3 sample relationships in different stages with active workflows and tasks. All five canonical queries verified against seed data. Non-workflow tables (brands, scans, reports, auth, billing) are unaffected."
    ]

    start -> write_types

    write_types -> verify_types

    verify_types -> write_migration [label="PASS" condition="preferred_label=PASS"]
    verify_types -> fix_types [label="FAIL", condition="preferred_label=FAIL"]
    fix_types -> verify_types [loop_restart=true]

    write_migration -> verify_migration

    verify_migration -> write_seed [label="PASS" condition="preferred_label=PASS"]
    verify_migration -> fix_migration [label="FAIL", condition="preferred_label=FAIL"]
    fix_migration -> verify_migration [loop_restart=true]

    write_seed -> verify_seed

    verify_seed -> verify_non_workflow [label="PASS" condition="preferred_label=PASS"]
    verify_seed -> fix_seed [label="FAIL", condition="preferred_label=FAIL"]
    fix_seed -> verify_seed [loop_restart=true]

    verify_non_workflow -> commit_changes [label="PASS" condition="preferred_label=PASS"]
    commit_changes -> done
    verify_non_workflow -> fix_collateral [label="FAIL", condition="preferred_label=FAIL"]
    fix_collateral -> verify_non_workflow [loop_restart=true]
}